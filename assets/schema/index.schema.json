          "label",
          "dims"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "device": {
            "type": "string"
          },
          "source_url": {
            "type": "string"
          },
          "dims": {
            "type": "array"
          }
        }
      }
    }
  }
}